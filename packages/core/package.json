{
  "name": "@apexpanda/core",
  "version": "1.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 node --env-file=../../.env -e \"require('tsx/cjs').register()\" tsx watch src/index.ts 2>/dev/null || cross-env NODE_OPTIONS=--max-old-space-size=8192 tsx watch src/index.ts",
    "start": "cross-env APEXPANDA_DASHBOARD_DIR=../dashboard/dist node --env-file=../../.env --max-old-space-size=8192 dist/index.js",
    "postinstall": "playwright install chromium || node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@apexpanda/shared": "workspace:*",
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.4.20",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@nut-tree-fork/nut-js": "^4.2.0",
    "@nut-tree-fork/shared": "^4.2.0",
    "@slack/bolt": "^3.17.0",
    "adm-zip": "^0.5.16",
    "apache-arrow": "^15.0.0",
    "busboy": "^1.6.0",
    "cheerio": "^1.2.0",
    "cron-parser": "^5.5.0",
    "cross-env": "^7.0.3",
    "discord.js": "^14.16.0",
    "fast-xml-parser": "^5.3.7",
    "form-data": "^4.0.0",
    "jimp": "^1.6.0",
    "js-yaml": "^4.1.0",
    "jsqr": "^1.4.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.3",
    "nodemailer": "^6.9.0",
    "pdf-parse": "^2.4.5",
    "playwright": "1.48.1",
    "qrcode": "^1.5.4",
    "sql.js": "^1.14.0",
    "ssh2": "^1.17.0",
    "tencentcloud-sdk-nodejs": "^4.1.186",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/busboy": "^1.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.5.13",
    "node-cron": "^3.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
