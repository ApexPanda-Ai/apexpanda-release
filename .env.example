# ============================================================
# ApexPanda 环境变量配置示例
# 复制为 .env 并填写所需参数后启动服务
# ============================================================

# ——— 基础路径 ———
# 可选：使用 .apexpanda/config.json 持久化配置，环境变量优先覆盖
# APEXPANDA_CONFIG_PATH=/path/to/config.json

# Dashboard 前端静态目录（本地开发默认 ./packages/dashboard/dist；Docker 建议 /app/packages/dashboard/dist）
APEXPANDA_DASHBOARD_DIR=./packages/dashboard/dist

# 完全控制模式：权限完全交给 AI
# - file-tools 可读写任意路径（不受 workspace 限制）
# - shell-exec 的 cwd 可任意目录
# - 打开程序时自动尝试常见路径、LLM 可主动搜索
APEXPANDA_FULL_CONTROL=true

# 数据目录（Agent、会话、工作流、知识库等；Docker 建议挂载 volume）
# APEXPANDA_DATA_DIR=.apexpanda

# 输出目录（Agent 生成文件、截图等，默认 .apexpanda/output）
# APEXPANDA_OUTPUT_DIR=.apexpanda/output

# 工作区目录（file-tools 读写范围）
# APEXPANDA_WORKSPACE=.apexpanda/workspace

# 端口
APEXPANDA_PORT=18790

# 公网可访问地址（MCP、Webhook URL 展示；如用 ngrok 则填 https://xxx.ngrok.io）
# APEXPANDA_BASE_URL=http://localhost:18790

# ——— LLM 配置 ———
# 若此处设置则覆盖 config.json，Settings 中的模型选择将不生效
# 留空则使用安装向导或 Settings 页面保存的 config.json
# APEXPANDA_LLM_BASE_URL=https://api.openai.com/v1
# APEXPANDA_LLM_API_KEY=sk-xxx
# APEXPANDA_LLM_MODEL=gpt-4o-mini

# 密钥仅从环境变量读取（不读 config.json，生产环境推荐）
# APEXPANDA_SECRETS_FROM_ENV_ONLY=true

# —— 国内模型示例（OpenAI 兼容 API）——
# DeepSeek
# APEXPANDA_LLM_BASE_URL=https://api.deepseek.com/v1
# APEXPANDA_LLM_API_KEY=sk-xxx
# APEXPANDA_LLM_MODEL=deepseek-chat

# 通义千问（阿里云）
# APEXPANDA_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# APEXPANDA_LLM_API_KEY=sk-xxx
# APEXPANDA_LLM_MODEL=qwen-turbo

# 豆包 / 火山引擎
# APEXPANDA_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# APEXPANDA_LLM_API_KEY=xxx
# APEXPANDA_LLM_MODEL=doubao-1-5-pro-32k-250115

# Kimi（月之暗面）
# APEXPANDA_LLM_BASE_URL=https://api.moonshot.cn/v1
# APEXPANDA_LLM_API_KEY=sk-xxx
# APEXPANDA_LLM_MODEL=moonshot-v1-8k

# 文心一言（百度）
# APEXPANDA_LLM_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
# APEXPANDA_LLM_API_KEY=xxx
# APEXPANDA_LLM_MODEL=ernie-4.0-8k

# 智谱 GLM
# APEXPANDA_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# APEXPANDA_LLM_API_KEY=xxx
# APEXPANDA_LLM_MODEL=glm-4-flash

# 模型路由（简单任务用廉价模型，复杂任务用主模型）
# APEXPANDA_MODEL_ROUTING_ENABLED=true
# APEXPANDA_MODEL_SIMPLE=gpt-4o-mini

# 模型故障转移（主模型 429/5xx/超时时自动切换备用）
# APEXPANDA_LLM_FALLBACK_MODEL=gpt-3.5-turbo

# ——— 渠道配置 ———

# 飞书（长连接模式，无需公网 URL；开放平台选「使用长连接接收事件」）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
# FEISHU_DOMAIN=lark  # 海外 Lark 时设置

# Telegram（长轮询，无需 Webhook）
# TELEGRAM_BOT_TOKEN=xxx

# Slack（Socket 模式，无需 Webhook；需在 Slack App 创建 App-Level Token，scope: connections:write）
# SLACK_BOT_TOKEN=xoxb-xxx
# SLACK_APP_TOKEN=xapp-xxx
# SLACK_SIGNING_SECRET=xxx

# Discord（Gateway 模式，需在 Discord Developer Portal 开启 Message Content Intent）
# DISCORD_BOT_TOKEN=xxx

# 钉钉（群机器人主动推送用 Webhook；Outgoing 机器人用 sessionWebhook 无需预配置）
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 企业微信（主动回复需配置）
# WECOM_CORP_ID=xxx
# WECOM_AGENT_ID=1000002
# WECOM_SECRET=xxx

# WhatsApp Cloud API（Meta 开发者平台）
# WHATSAPP_VERIFY_TOKEN=your-verify-token
# WHATSAPP_ACCESS_TOKEN=xxx
# WHATSAPP_PHONE_NUMBER_ID=xxx

# ——— 权限与安全 ———


# API Key 认证（可选）
# - 未设置时自动生成并写入 .apexpanda/api-key，启动日志输出 Key
# - 设置后 /api/v1/* 需携带 Authorization: Bearer <key> 或 X-API-Key: <key>
# - 置空 APEXPANDA_API_KEY="" 或设 APEXPANDA_DISABLE_AUTO_KEY=true 可关闭认证（免登录）
# APEXPANDA_API_KEY=your-secret-api-key
# APEXPANDA_DISABLE_AUTO_KEY=true

# RBAC 权限（需同时设置 APEXPANDA_API_KEY，否则不生效）
# APEXPANDA_RBAC_ENABLED=true
# APEXPANDA_DEFAULT_ROLE=admin

# CORS 允许来源（默认 *）
# APEXPANDA_CORS_ORIGIN=*

# 敏感词过滤（逗号/分号分隔，APEXPANDA_SENSITIVE_BLOCK=true 时拦截）
# APEXPANDA_SENSITIVE_WORDS=词1,词2
# APEXPANDA_SENSITIVE_BLOCK=false

# ——— 性能调优 ———

# 工具调用最大轮数（复杂任务链式执行，默认 12；搭建环境、多步任务需更多轮）
APEXPANDA_MAX_TOOL_ROUNDS=30

# 工具调用超时（毫秒，默认 300000=5 分钟；remote-exec/pentest 等建议 600000）
APEXPANDA_TOOL_TIMEOUT_MS=600000

# 会话历史条数（送入 LLM 的 context，默认 16）
# APEXPANDA_HISTORY_LIMIT=16

# 工具调用日志（设 true 时每笔调用输出 [tool-call] JSON 到控制台，便于复盘优化）
# APEXPANDA_TOOL_LOG_ENABLED=true

# Skill 沙箱（默认启用，按 APEX_SKILL.yaml 权限声明校验）
# APEXPANDA_SKILL_SANDBOX_ENABLED=true

# 循环检测（重复 tool-call 时警告）
# APEXPANDA_LOOP_DETECTION_ENABLED=true
# APEXPANDA_LOOP_WARNING_THRESHOLD=4

# ——— 持久化 ———

# 会话文件持久化
# 会话历史持久化（默认开启；设 false 可关闭，重启后会话不保留）
# APEXPANDA_SESSIONS_PERSIST=false

# 知识库持久化（默认 LanceDB，重启后保留）
# APEXPANDA_KNOWLEDGE_PERSIST=true

# LanceDB 路径（默认 .apexpanda/knowledge.lance；换 embedding 模型时需清库重建）
# APEXPANDA_KNOWLEDGE_LANCE_PATH=.apexpanda/knowledge.lance

# 知识库分块：每块字数、重叠字数（char 模式默认 500/50）
# APEXPANDA_CHUNK_SIZE=500
# APEXPANDA_CHUNK_OVERLAP=50

# 分块策略：char（固定字符）/ heading（按 Markdown 标题）/ case（按案例边界）
# APEXPANDA_CHUNK_STRATEGY=char

# 混合检索（BM25 + 本地向量，默认开启；设 false 回退为 LanceDB + 可选外部 Embedding API）
# APEXPANDA_HYBRID_SEARCH_ENABLED=true

# 本地 Embedding 模型（混合检索时使用，512 维）
# APEXPANDA_EMBEDDING_MODEL=Xenova/bge-small-zh-v1.5
# APEXPANDA_EMBEDDING_MODEL_PATH=  # 离线部署：本地模型目录

# 本地 Rerank（可选，混合检索后精细排序）
# APEXPANDA_RERANK_ENABLED=false
# APEXPANDA_RERANK_MODEL=Xenova/bge-reranker-base
# APEXPANDA_RERANK_MODEL_PATH=  # 离线部署：本地模型目录

# BM25 索引持久化（大知识库建议开启，重启时从 .apexpanda/bm25-index.json 加载）
# APEXPANDA_BM25_PERSIST=false

# 旧版：外部 Embedding API（仅当 APEXPANDA_HYBRID_SEARCH_ENABLED=false 时生效）
# APEXPANDA_EMBEDDING_ENABLED=false
# APEXPANDA_EMBEDDING_BASE_URL=https://api.openai.com/v1
# APEXPANDA_EMBEDDING_API_KEY=sk-xxx
# APEXPANDA_EMBEDDING_MODEL=text-embedding-3-small

# 长期记忆持久化（默认内存，重启丢失；设 true 写入 .apexpanda/memory.json）
# APEXPANDA_MEMORY_PERSIST=true

# 工作流持久化（默认内存）
# APEXPANDA_WORKFLOWS_PERSIST=true

# 工作流步骤超时（毫秒，默认 300000=5 分钟；动态规划等复杂任务可设 600000）
APEXPANDA_WORKFLOW_STEP_TIMEOUT_MS=600000

# ——— Skills ———

# 内置 Skills 目录（Docker 部署时需设为 /app/packages/skills/builtin）
# APEXPANDA_SKILLS_DIR=./packages/skills/builtin

# 用户 Skills 目录（可选，默认 .apexpanda/skills）
# APEXPANDA_USER_SKILLS_DIR=.apexpanda/skills

# 工作区 Skills 目录（最高优先级）
# APEXPANDA_WORKSPACE_SKILLS_DIR=.apexpanda/workspace/skills

# 额外 Skills 目录（逗号分隔）
# APEXPANDA_SKILLS_EXTRA_DIRS=

# 技能热重载（修改 SKILL 文件后自动刷新）
# APEXPANDA_SKILLS_WATCH=false
# APEXPANDA_SKILLS_WATCH_DEBOUNCE_MS=250

# 从 Git URL 导入 Skill 时指定分支（可选，不设则 clone 默认分支）
# APEXPANDA_SKILL_IMPORT_BRANCH=main

# GitHub 镜像（直连失败时配置，例：https://mirror.ghproxy.com/）
# APEXPANDA_GITHUB_MIRROR=https://mirror.ghproxy.com/

# OpenClaw 兼容（默认启用，支持从 SKILL.md 加载，可设 false 禁用）
# APEXPANDA_OPENCLAW_COMPAT_ENABLED=true

# ——— 第三方 Skill Keys ———

# 知识库 Rerank（提升 RAG 检索相关性）
# JINA_API_KEY=xxx
# COHERE_API_KEY=xxx

# 阿里云 NLS（asr-aliyun / tts-aliyun Skill）
# ALIYUN_ACCESS_KEY_ID=xxx
# ALIYUN_ACCESS_KEY_SECRET=xxx
# ALIYUN_NLS_APPKEY=xxx
# ALIYUN_NLS_REGION=cn-shanghai

# 讯飞 ASR（asr-xunfei Skill）
# XFYUN_APP_ID=xxx
# XFYUN_API_KEY=xxx
# XFYUN_API_SECRET=xxx

# 阿里云百炼 / 通义万相（image-gen-wanx Skill）
# DASHSCOPE_API_KEY=sk-xxx

# Azure 语音（tts-azure / asr-azure Skill）
# AZURE_SPEECH_KEY=xxx
# AZURE_SPEECH_REGION=eastasia

# Vosk 离线唤醒词模型路径（可选，默认 userData/vosk-models）
# APEXPANDA_VOSK_MODEL_PATH=/path/to/vosk-model

# Stable Diffusion（image-gen-sd Skill，默认 http://127.0.0.1:7860）
# STABLE_DIFFUSION_API_URL=http://127.0.0.1:7860

# 高德地图（map-amap Skill）
# AMAP_WEB_SERVICE_KEY=xxx

# 百度地图（map-baidu Skill）
# BAIDU_MAP_AK=xxx

# Brave 搜索（web-search-brave Skill）
# BRAVE_API_KEY=xxx

# Tavily 搜索（web-search-tavily Skill）
# TAVILY_API_KEY=xxx

# Google 搜索（web-search-google Skill；在 programmablesearchengine.google.com 创建并选「搜索整个网页」）
# GOOGLE_CSE_API_KEY=xxx
# GOOGLE_CSE_CX=xxx

# 百度翻译（translate-baidu Skill）
# BAIDU_TRANSLATE_APPID=xxx
# BAIDU_TRANSLATE_SECRET=xxx

# GitHub（github Skill）
# GITHUB_TOKEN=ghp_xxx

# SMTP 邮件（email-smtp Skill）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user
# SMTP_PASS=pass
# SMTP_FROM=noreply@example.com

# ——— 高级 ———

# Webhook 触发工作流（设置后需在请求头携带 X-Webhook-Secret）
# APEXPANDA_WEBHOOK_SECRET=your-webhook-secret

# MCP 服务端（默认启用，供 Cursor/Claude Code 接入；设 false 禁用）
# APEXPANDA_MCP_ENABLED=true

# 任务队列（debounce 毫秒、容量、丢弃策略 oldest|summarize）
# APEXPANDA_QUEUE_DEBOUNCE_MS=1000
# APEXPANDA_QUEUE_CAP=20
# APEXPANDA_QUEUE_DROP_STRATEGY=summarize

# Redis（可选，任务队列持久化）
# CHANNEL_QUEUE_REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://localhost:6379
